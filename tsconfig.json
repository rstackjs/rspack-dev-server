{
  "compilerOptions": {
    "module": "preserve",
    "moduleResolution": "bundler",
    "target": "ES2021",
    "esModuleInterop": true,
    "declaration": true,
    "isolatedModules": true,
    "composite": true,
    "forceConsistentCasingInFileNames": true,
    "checkJs": true,
    "strict": true,
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "outDir": "dist",
    "rootDir": "src"
  },
  "references": [
    {
      "path": "./tsconfig.client.json"
    }
  ],
  "include": ["src/**/*"]
}
